<script type="text/x-dc" data-dc-script="" data-props="{&quot;howLabel&quot;: &quot;How it works&quot;, &quot;howSubtitle&quot;: &quot;Three textures, one happy dog&quot;, &quot;step1Title&quot;: &quot;Stop the inhaling&quot;, &quot;step1Desc&quot;: &quot;Spread wet food, yoghurt or peanut butter across the ridges so every lick takes real effort.&quot;, &quot;step2Title&quot;: &quot;Keep them locked in&quot;, &quot;step2Desc&quot;: &quot;Licking releases calming endorphins \u2014 the textured maze keeps their mind busy for ages.&quot;, &quot;step3Title&quot;: &quot;Finally, peace &amp; quiet&quot;, &quot;step3Desc&quot;: &quot;Suction base locks it down. They stay calm and occupied while you get a moment to yourself.&quot;}">
class Component extends DCLogic {
  constructor(props) {
    super(props);
    this.IMAGES = [
      window.__resources.img0 || 'https://njoypetco.com/cdn/shop/files/pomelli-image_13.png?v=1773710685&width=500',
      window.__resources.img1 || 'https://njoypetco.com/cdn/shop/files/pomelli-image_15.png?v=1773710685&width=500',
      window.__resources.img2 || 'https://njoypetco.com/cdn/shop/files/pomelli-image_12.jpg?v=1773710685&width=500',
      window.__resources.img3 || 'https://njoypetco.com/cdn/shop/files/pomelli-image_14.jpg?v=1773710685&width=500',
      window.__resources.img4 || 'https://njoypetco.com/cdn/shop/files/ChatGPT_Image_Mar_14_2026_11_58_42_AM.png?v=1773710685&width=500',
      window.__resources.img5 || 'https://njoypetco.com/cdn/shop/files/0ddc9faa-adcd-4bb8-ab88-c11d61b24a4a.jpg?v=1773710685&width=500',
    ];
    this.FAQS = [
      { q: 'Will it work for fast, food-obsessed dogs?', a: 'Absolutely — that\u2019s exactly what it\u2019s built for. The three textured zones force your dog to lick and work for every bite, slowing a 10-second gulp down to 10+ minutes of healthy, paced eating.' },
      { q: 'What can I put on it?', a: 'Anything spreadable: wet food, raw, plain yoghurt, peanut butter (xylitol-free), pumpkin, mashed banana or softened kibble. Freeze it for a longer-lasting summer treat.' },
      { q: 'Is the silicone safe?', a: 'Yes. It\u2019s made from BPA-free, food-grade silicone that\u2019s non-toxic and pet-safe \u2014 the same material used in baby and kitchen products.' },
      { q: 'How do I clean it?', a: 'Rinse under warm water, or pop it on the top rack of your dishwasher. The flexible silicone makes it easy to push food out of every groove.' },
      { q: 'Will it slide around the floor?', a: 'No \u2014 the strong suction base grips smooth floors, crates, walls and bath tubs so it stays firmly in place while your dog goes to town.' },
      { q: 'Does it suit cats too?', a: 'It does. Cats love the lick-mat textures for slow feeding and calming enrichment, and the suction works just as well for them.' },
    ];
  }

  state = { sel: 0, qty: 1, cart: 0, toast: null, toastKey: 0, openFaq: -1, sticky: false, gif1: null, gif2: null, gif3: null };

  componentDidMount() {
    this._revealSeen = new WeakSet();
    const io = this._io = new IntersectionObserver((entries) => {
      for (const en of entries) {
        if (en.isIntersecting) {
          en.target.style.opacity = '1';
          en.target.style.transform = 'none';
          io.unobserve(en.target);
        }
      }
    }, { threshold: 0.1 });
    const scan = () => {
      document.querySelectorAll('[data-reveal]').forEach((el) => {
        if (this._revealSeen.has(el)) return;
        this._revealSeen.add(el);
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight * 0.92) return;
        el.style.opacity = '0';
        el.style.transform = 'translateY(30px)';
        el.style.transition = 'opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1)';
        io.observe(el);
      });
    };
    scan();
    this._scanTimer = setInterval(scan, 700);
    setTimeout(() => clearInterval(this._scanTimer), 9000);

    ['gif1','gif2','gif3'].forEach(k => {
      const v = localStorage.getItem('njoy-how-' + k);
      if (v) this.setState({ [k]: v });
    });
    this._onScroll = () => {
      const show = window.scrollY > 720;
      if (show !== this.state.sticky) this.setState({ sticky: show });
    };
    window.addEventListener('scroll', this._onScroll, { passive: true });
  }

  componentWillUnmount() {
    clearInterval(this._scanTimer);
    if (this._io) this._io.disconnect();
    clearTimeout(this._toastT);
    window.removeEventListener('scroll', this._onScroll);
  }

  handleGifChange(n, e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      const key = 'njoy-how-gif' + n;
      try { localStorage.setItem(key, ev.target.result); } catch (_) {}
      this.setState({ ['gif' + n]: ev.target.result });
    };
    reader.readAsDataURL(file);
  }

  fireToast(msg) {
    this.setState((s) => ({ toast: msg, toastKey: s.toastKey + 1 }));
    clearTimeout(this._toastT);
    this._toastT = setTimeout(() => this.setState({ toast: null }), 2400);
